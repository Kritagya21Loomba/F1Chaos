---
import Base from '../../layouts/Base.astro';
import MultiSeriesChart from '../../components/charts/MultiSeriesChart';
import DriverMovementChart from '../../components/charts/DriverMovementChart';
import { DATA_SLUG_TO_URL, RACE_META, SEASON_COLORS } from '../../data/races';
import type { ChartSeries } from '../../components/charts/MultiSeriesChart';

export async function getStaticPaths() {
  const allMetrics = import.meta.glob('../../../public/metrics/*.json', { eager: true });

  // Group metrics by dataSlug (circuit identity), deduplicating by year
  const bySlug: Record<string, Map<number, any>> = {};
  for (const [filePath, raw] of Object.entries(allMetrics)) {
    const filename = filePath.split('/').pop()!.replace('.json', '');
    const sepIdx   = filename.indexOf('_');
    const yearStr  = filename.slice(0, sepIdx);
    const dataSlug = filename.slice(sepIdx + 1);
    const year     = parseInt(yearStr);
    if (!bySlug[dataSlug]) bySlug[dataSlug] = new Map();
    bySlug[dataSlug].set(year, (raw as any).default ?? raw);
  }

  // Only generate a page for circuits present in 2+ different years
  return Object.entries(bySlug)
    .filter(([, yearMap]) => yearMap.size > 1)
    .map(([dataSlug, yearMap]) => {
      const entries = [...yearMap.entries()]
        .sort(([a], [b]) => a - b)
        .map(([year, metrics]) => ({ year, metrics }));
      const urlSlug = DATA_SLUG_TO_URL[dataSlug] ?? dataSlug;
      return {
        params: { race: urlSlug },
        props:  { dataSlug, urlSlug, entries },
      };
    });
}

const { dataSlug, urlSlug, entries } = Astro.props;
const meta = RACE_META[dataSlug];

// Build per-year series for charts
const inversionSeries: ChartSeries[] = entries.map(e => ({
  key:   String(e.year),
  label: String(e.year),
  color: SEASON_COLORS[e.year] ?? '#7070a0',
  data:  (e.metrics.inversions_per_lap ?? []).map((d: any) => ({ lap: d.lap, value: d.inversions })),
}));

const cumulativeSeries: ChartSeries[] = entries.map(e => ({
  key:   String(e.year),
  label: String(e.year),
  color: SEASON_COLORS[e.year] ?? '#7070a0',
  data:  (e.metrics.cumulative_inversions ?? []).map((d: any) => ({ lap: d.lap, value: d.cumulative })),
}));

// Build all sequential year-over-year pairs (e.g. 2024->2025, 2025->2026)
// Plus total range if 3+ years (e.g. 2024->2026)
interface YearPair {
  fromYear: number;
  toYear: number;
  fromMetrics: any;
  toMetrics: any;
  label: string;
  isRange: boolean; // true = not adjacent (full range)
}

const pairs: YearPair[] = [];
// Adjacent pairs
for (let i = 0; i < entries.length - 1; i++) {
  pairs.push({
    fromYear:    entries[i].year,
    toYear:      entries[i + 1].year,
    fromMetrics: entries[i].metrics,
    toMetrics:   entries[i + 1].metrics,
    label:       `${entries[i].year} → ${entries[i + 1].year}`,
    isRange:     false,
  });
}
// Total range (first → last) if 3+ years
if (entries.length >= 3) {
  pairs.push({
    fromYear:    entries[0].year,
    toYear:      entries[entries.length - 1].year,
    fromMetrics: entries[0].metrics,
    toMetrics:   entries[entries.length - 1].metrics,
    label:       `${entries[0].year} → ${entries[entries.length - 1].year} (total)`,
    isRange:     true,
  });
}
---

<Base title={`Compare — ${meta?.shortName ?? urlSlug}`} activeNav="compare">

  <!-- ══════════════════════════════════════════════ CIRCUIT COMPARE HERO -->
  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-angle"></div>
    <div class="page-hero-glow"></div>
    <div class="page-hero-inner">
      <div class="page-hero-eye">
        <span class="page-hero-dot"></span>
        Circuit Comparison &mdash; {entries.map(e => e.year).join(' · ')}
      </div>
      <h1 class="page-hero-title">{meta?.name ?? urlSlug}</h1>
      <p class="page-hero-sub">
        {meta?.circuit} &mdash; side-by-side chaos metrics across seasons at this circuit.
      </p>
    </div>
  </section>

  <div class="container" style="padding-top: 48px; padding-bottom: 80px;">

    <!-- ── Section 1: Year snapshot cards ──────────────────────────────────── -->
    <div class="section">
      <div class="section-title">Race Snapshots by Year</div>
      <div class="section-desc">Key metrics for each year at this circuit, side by side.</div>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 20px; margin-bottom: 8px;">
        {entries.map(e => {
          const m      = e.metrics;
          const color  = SEASON_COLORS[e.year] ?? '#7070a0';
          const winner = m.driver_movements?.[0];
          return (
            <div class={`compare-card y${e.year}`}>
              <div class="c-label">Season</div>
              <div class="c-year">{e.year}</div>
              <div class="c-metric">
                <div class="l">Lap inversions</div>
                <div class="v">{m.total_lap_inversions}</div>
              </div>
              <div class="c-metric">
                <div class="l">Volatility score</div>
                <div class="v">{m.volatility_score}</div>
              </div>
              <div class="c-metric">
                <div class="l">Start &rarr; finish</div>
                <div class="v">{m.total_inversions}</div>
              </div>
              <div class="c-metric">
                <div class="l">DNFs</div>
                <div class="v">{m.dnf_count}</div>
              </div>
              {winner && (
                <div class="c-metric">
                  <div class="l">Winner</div>
                  <div class="v" style="font-size: 20px;">{winner.code}</div>
                </div>
              )}
              {m.biggest_mover && (
                <div class="c-metric">
                  <div class="l">Biggest mover</div>
                  <div class="v" style={`font-size: 16px; color: ${color};`}>
                    {m.biggest_mover.code} +{m.biggest_mover.positions_gained}
                  </div>
                </div>
              )}
              <div style="margin-top: 16px;">
                <a href={`/${e.year}/${urlSlug}`} style={`font-size: 13px; color: ${color};`}>
                  Full {e.year} race &rarr;
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- ── Race Vitals at a Glance ──────────────────────────────────────── -->
    <div class="section">
      <div class="section-title">Race Vitals at a Glance</div>
      <div class="section-desc">
        Side-by-side key facts from each year's race at this circuit.
      </div>
      <div class="vitals-grid">

        {/* Header row */}
        <div class="vg-row vg-head">
          <div class="vg-metric-label"></div>
          {entries.map(e => (
            <div class="vg-val vg-year-head" style={`color: ${SEASON_COLORS[e.year] ?? '#7070a0'};`}>
              {e.year}
            </div>
          ))}
        </div>

        {/* Volatility */}
        <div class="vg-row vg-highlight">
          <div class="vg-metric-label">Volatility Score</div>
          {entries.map(e => {
            const c = SEASON_COLORS[e.year] ?? '#7070a0';
            return <div class="vg-val" style={`color: ${c}; font-weight: 700;`}>{e.metrics.volatility_score ?? '—'}</div>;
          })}
        </div>

        {/* Lap inversions */}
        <div class="vg-row">
          <div class="vg-metric-label">Lap Inversions</div>
          {entries.map(e => (
            <div class="vg-val">{(e.metrics.total_lap_inversions ?? 0).toLocaleString()}</div>
          ))}
        </div>

        {/* On-track overtakes */}
        <div class="vg-row">
          <div class="vg-metric-label">On-Track Overtakes</div>
          {entries.map(e => {
            const ot = e.metrics.overtake_summary?.on_track;
            return <div class="vg-val">{ot != null ? ot : '—'}</div>;
          })}
        </div>

        {/* SC / VSC */}
        <div class="vg-row">
          <div class="vg-metric-label">SC / VSC Events</div>
          {entries.map(e => {
            const sc  = e.metrics.track_status?.sc_count  ?? 0;
            const vsc = e.metrics.track_status?.vsc_count ?? 0;
            const txt = sc + vsc > 0 ? `${sc} SC · ${vsc} VSC` : 'None';
            const col = sc + vsc > 0 ? 'var(--accent2)' : 'var(--muted)';
            return <div class="vg-val" style={`color: ${col};`}>{txt}</div>;
          })}
        </div>

        {/* DNFs */}
        <div class="vg-row">
          <div class="vg-metric-label">DNFs</div>
          {entries.map(e => {
            const d = e.metrics.dnf_count ?? 0;
            return <div class="vg-val" style={d > 2 ? 'color: var(--accent);' : ''}>{d}</div>;
          })}
        </div>

        {/* Winner */}
        <div class="vg-row">
          <div class="vg-metric-label">Winner</div>
          {entries.map(e => {
            const w = e.metrics.driver_movements?.[0];
            const c = SEASON_COLORS[e.year] ?? '#7070a0';
            return <div class="vg-val" style={`color: ${c}; font-weight: 700;`}>{w?.code ?? '—'}</div>;
          })}
        </div>

        {/* Winner's grid slot */}
        <div class="vg-row">
          <div class="vg-metric-label">Winner Started</div>
          {entries.map(e => {
            const gs = e.metrics.driver_movements?.[0]?.grid_start;
            const gained = gs != null ? Math.max(0, gs - 1) : 0;
            return (
              <div class="vg-val" style={gained >= 5 ? 'color: var(--green);' : ''}>
                {gs != null ? `P${gs}` : '—'}
              </div>
            );
          })}
        </div>

        {/* Biggest mover */}
        <div class="vg-row vg-last">
          <div class="vg-metric-label">Biggest Mover</div>
          {entries.map(e => {
            const bm = e.metrics.biggest_mover;
            return (
              <div class="vg-val" style={bm ? 'color: var(--green);' : 'color: var(--muted);'}>
                {bm ? `${bm.code} +${bm.positions_gained}` : '—'}
              </div>
            );
          })}
        </div>

      </div>
    </div>

    <!-- ── Podium Comparison ──────────────────────────────────────────────── -->
    <div class="section">
      <div class="section-title">Podium Comparison</div>
      <div class="section-desc">
        Who stood on the podium at {meta?.name ?? urlSlug} across the years?
        Grid start positions shown in brackets &mdash; green = gained places to podium.
      </div>
      <div class="podium-compare-grid">
        {entries.map(e => {
          const top3 = (e.metrics.driver_movements ?? []).slice(0, 3);
          const color = SEASON_COLORS[e.year] ?? '#7070a0';
          const posLabels = ['P1', 'P2', 'P3'];
          return (
            <div class="pyc-card" style={`--pyc-c: ${color};`}>
              <div class="pyc-year">{e.year}</div>
              <div class="pyc-circuit">{meta?.shortName ?? urlSlug}</div>
              <div class="pyc-positions">
                {top3.map((d, i) => {
                  const gained = d.positions_gained ?? 0;
                  const gainCol = gained > 0 ? 'var(--green)' : gained < 0 ? 'var(--accent)' : 'var(--muted)';
                  return (
                    <div class={`pyc-pos pyc-p${i + 1}`}>
                      <span class="pyc-pos-label">{posLabels[i]}</span>
                      <span class="pyc-driver">{d.code}</span>
                      <span class="pyc-gain" style={`color: ${gainCol};`}>
                        {d.grid_start != null ? `P${d.grid_start}` : ''}
                        {gained !== 0 ? ` ${gained > 0 ? '+' : ''}${gained}` : ''}
                      </span>
                    </div>
                  );
                })}
                {top3.length === 0 && (
                  <div style="color: var(--muted); font-size: 13px; padding: 8px 0;">No data</div>
                )}
              </div>
              <a href={`/${e.year}/${urlSlug}`} class="pyc-link">
                Full {e.year} race &rarr;
              </a>
            </div>
          );
        })}
      </div>
    </div>

    <!-- ── Section 2: Year-over-year deltas ────────────────────────────────── -->
    <div class="section">
      <div class="section-title">Year-over-Year Changes</div>
      <div class="section-desc">
        How much did volatility shift between seasons?
        Green = increased chaos, red = decreased.
        {entries.length >= 3 && <>&nbsp;The <em>total</em> row spans the full {entries[0].year}&ndash;{entries[entries.length - 1].year} range.</>}
      </div>

      <div style="display: flex; flex-direction: column; gap: 16px;">
        {pairs.map(pair => {
          const invDelta  = pair.toMetrics.total_lap_inversions - pair.fromMetrics.total_lap_inversions;
          const volDelta  = +(pair.toMetrics.volatility_score - pair.fromMetrics.volatility_score).toFixed(4);
          const pctChange = Math.round((pair.toMetrics.total_lap_inversions / pair.fromMetrics.total_lap_inversions - 1) * 100);
          const isPos     = invDelta >= 0;
          const borderStyle = pair.isRange ? '1px dashed #2a2a3f' : '1px solid #2a2a3f';

          return (
            <div style={`background: var(--surface); border: ${borderStyle}; border-radius: 12px; padding: 20px 24px;`}>
              <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px; flex-wrap: wrap;">
                <span style={`font-size: 13px; font-weight: 600; color: ${SEASON_COLORS[pair.fromYear] ?? '#7070a0'};`}>
                  {pair.fromYear}
                </span>
                <span style="color: var(--muted); font-size: 14px;">&rarr;</span>
                <span style={`font-size: 13px; font-weight: 600; color: ${SEASON_COLORS[pair.toYear] ?? '#7070a0'};`}>
                  {pair.toYear}
                </span>
                {pair.isRange && (
                  <span style="margin-left: 4px; font-size: 10px; background: var(--surface2); color: var(--muted); border-radius: 4px; padding: 2px 8px; letter-spacing: 0.1em; text-transform: uppercase;">
                    Full Range
                  </span>
                )}
              </div>
              <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 16px;">
                <div>
                  <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); margin-bottom: 4px;">Inversion delta</div>
                  <div style={`font-size: 28px; font-weight: 700; font-family: var(--font-mono); color: ${isPos ? 'var(--green)' : 'var(--accent)'};`}>
                    {isPos ? '+' : ''}{invDelta}
                  </div>
                  <div style="font-size: 11px; color: var(--muted);">lap inversions</div>
                </div>
                <div>
                  <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); margin-bottom: 4px;">Volatility delta</div>
                  <div style={`font-size: 28px; font-weight: 700; font-family: var(--font-mono); color: ${volDelta >= 0 ? 'var(--green)' : 'var(--accent)'};`}>
                    {volDelta >= 0 ? '+' : ''}{volDelta}
                  </div>
                  <div style="font-size: 11px; color: var(--muted);">score change</div>
                </div>
                <div>
                  <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); margin-bottom: 4px;">Change</div>
                  <div style={`font-size: 28px; font-weight: 700; font-family: var(--font-mono); color: ${pctChange >= 0 ? 'var(--green)' : 'var(--accent)'};`}>
                    {pctChange >= 0 ? '+' : ''}{pctChange}%
                  </div>
                  <div style="font-size: 11px; color: var(--muted);">more chaos</div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- ── Section 3: Charts ─────────────────────────────────────────────── -->
    <div class="section">
      <div class="section-title">Inversions Per Lap — All Years</div>
      <div class="section-desc">
        {entries.map(e => e.year).join(' vs ')} — hover for exact values. Higher peaks = more overtaking activity.
      </div>
      <div class="card chart-wrap">
        <MultiSeriesChart
          client:load
          series={inversionSeries}
          yLabel="Inversions per Lap"
          height={320}
        />
      </div>
    </div>

    <div class="section">
      <div class="section-title">Cumulative Inversions — Race Chaos Over Time</div>
      <div class="section-desc">
        Steeper slope = more chaotic phase. The gap between curves shows the effect of regulation changes.
      </div>
      <div class="card chart-wrap">
        <MultiSeriesChart
          client:load
          series={cumulativeSeries}
          yLabel="Cumulative Inversions"
          height={320}
        />
      </div>
    </div>

    <!-- ── Section 4: Driver movement per year ──────────────────────────── -->
    <div class="section">
      <div class="section-title">Driver Position Changes by Year</div>
      <div class="section-desc">
        Positions gained (green) or lost (red) from grid start to finish.
        DNF drivers shown in grey.
      </div>
      {entries.map(e => (
        <div style="margin-bottom: 32px;">
          <div style={`font-size: 13px; font-weight: 600; color: ${SEASON_COLORS[e.year] ?? '#7070a0'}; margin-bottom: 12px; letter-spacing: 0.06em; text-transform: uppercase;`}>
            {e.year} Race
          </div>
          <div class="card chart-wrap tall">
            <DriverMovementChart client:load data={e.metrics.driver_movements} height={480} />
          </div>
        </div>
      ))}
    </div>

    <div class="insight">
      <div class="title">Methodology</div>
      <p>
        Inversions are counted using a <strong>Fenwick Tree (BIT)</strong> per lap,
        measuring each lap's position array against the original grid order.
        Start&rarr;finish totals use a <strong>MergeSort-based counter</strong>.
        DNF drivers are excluded from inversion counts but shown in movement charts.
        Data via <strong>FastF1</strong>.
      </p>
    </div>

    <div style="margin-top: 32px;">
      <a href="/compare" class="race-card" style="display: inline-block; padding: 16px 20px; max-width: 300px;">
        <div style="font-size: 13px; color: var(--muted);">Back to</div>
        <div style="font-size: 18px; font-weight: 700;">&larr; Season Comparison</div>
      </a>
    </div>
  </div>
</Base>

<style>
/* ── Race Vitals grid ─────────────────────────────────────── */
.vitals-grid {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  overflow: hidden;
}

.vg-row {
  display: flex;
  align-items: center;
  border-bottom: 1px solid var(--border);
  transition: background 0.15s;
}

.vg-row:hover:not(.vg-head) { background: var(--surface2); }
.vg-last { border-bottom: none; }

.vg-head {
  background: var(--surface2);
  border-bottom: 2px solid var(--border);
}

.vg-highlight {
  background: color-mix(in srgb, var(--accent) 4%, var(--surface));
}

.vg-metric-label {
  width: 190px;
  flex-shrink: 0;
  padding: 13px 20px;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--muted);
}

.vg-val {
  flex: 1;
  padding: 13px 8px;
  font-size: 14px;
  font-family: var(--font-mono);
  text-align: center;
  color: var(--text);
}

.vg-year-head {
  font-size: 20px;
  font-weight: 900;
  letter-spacing: -0.02em;
  padding: 14px 8px;
}

/* ── Podium Comparison ────────────────────────────────────── */
.podium-compare-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 16px;
}

.pyc-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-left: 4px solid var(--pyc-c, var(--accent));
  border-radius: 12px;
  padding: 22px;
  position: relative;
  overflow: hidden;
  transition: transform 0.15s, box-shadow 0.2s;
}

.pyc-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at top left, color-mix(in srgb, var(--pyc-c, var(--accent)) 8%, transparent), transparent 55%);
  pointer-events: none;
}

.pyc-year {
  font-size: 40px;
  font-weight: 900;
  font-family: var(--font-mono);
  letter-spacing: -0.03em;
  color: var(--pyc-c, var(--accent));
  line-height: 1;
  margin-bottom: 2px;
}

.pyc-circuit {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--muted);
  margin-bottom: 16px;
}

.pyc-positions {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin-bottom: 16px;
}

.pyc-pos {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 7px 12px;
  border-radius: 7px;
}

.pyc-p1 { background: rgba(255,180,0,0.1); border: 1px solid rgba(255,180,0,0.3); }
.pyc-p2 { background: rgba(192,192,192,0.06); border: 1px solid rgba(192,192,192,0.2); }
.pyc-p3 { background: rgba(160,100,40,0.08); border: 1px solid rgba(160,100,40,0.25); }

.pyc-pos-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--muted);
  width: 18px;
  flex-shrink: 0;
}

.pyc-driver {
  font-size: 16px;
  font-weight: 700;
  font-family: var(--font-mono);
  flex: 1;
  color: var(--text);
}

.pyc-gain {
  font-size: 11px;
  font-family: var(--font-mono);
  font-weight: 600;
}

.pyc-link {
  font-size: 12px;
  font-weight: 600;
  color: var(--pyc-c, var(--accent));
  text-decoration: none;
}

.pyc-link:hover { text-decoration: underline; }

@media (max-width: 640px) {
  .vg-metric-label { width: 130px; font-size: 10px; padding: 11px 12px; }
  .vg-val { font-size: 12px; padding: 11px 4px; }
  .vg-year-head { font-size: 16px; }
}
</style>
