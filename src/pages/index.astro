  from { opacity: 0; transform: translateY(26px); }
  to   { opacity: 1; transform: translateY(0); }
}

@keyframes glowPulse {
  0%, 100% { box-shadow: 0 0 0   0 rgba(225,6,0,0.0); }
  50%       { box-shadow: 0 0 0 6px rgba(225,6,0,0.3); }
}

/* ═══════════════════════════════════════════════════════ RESPONSIVE */
@media (max-width: 900px) {
  .hero { min-height: auto; padding: 60px 0 80px; }
  .algo-panel { flex-direction: column; }
  .algo-step { border-right: none; border-bottom: 1px solid var(--border); }
  .algo-step:first-child { border-left: 4px solid var(--accent); border-bottom: 1px solid var(--border); }
  .algo-step:last-child { border-bottom: none; }
  .algo-arrow { display: none; }
}

@media (max-width: 720px) {
  .stats-band-inner { flex-wrap: wrap; }
  .sb-item { min-width: calc(50% - 1px); padding: 20px 16px; }
  .sb-sep { display: none; }
  .compare-cta { flex-direction: column; align-items: flex-start; }
  .cta-arrow-btn { width: 100%; justify-content: center; }
}

@media (max-width: 480px) {
  .hero-title { font-size: clamp(40px, 13vw, 60px); }
  .hero-t2 { -webkit-text-stroke-width: 2px; }
  .hero-ctas { flex-direction: column; }
  .cta-primary, .cta-secondary { width: 100%; justify-content: center; }
  .scard-year { font-size: 40px; }
  .scard-bg-year { font-size: 80px; }
}
</style>

<script>
  // Count-up animation for stats band
  const countEls = document.querySelectorAll('.count-up');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.target ?? '0', 10);
      const duration = 1500;
      const startTime = performance.now();

      function frame(now: number) {
        const progress = Math.min((now - startTime) / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
        el.textContent = Math.round(eased * target).toLocaleString();
        if (progress < 1) requestAnimationFrame(frame);
      }

      requestAnimationFrame(frame);
      observer.unobserve(el);
    });
  }, { threshold: 0.4 });

  countEls.forEach(el => observer.observe(el));
</script>
