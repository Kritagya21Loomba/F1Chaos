---
import Base from '../layouts/Base.astro';
import SeasonTrendChart from '../components/charts/SeasonTrendChart';
import { SEASON_COLORS } from '../data/races';

const allMetrics = import.meta.glob('../../public/metrics/*.json', { eager: true });

const byYear: Record<number, { dataSlug: string; metrics: any }[]> = {};
for (const [filePath, raw] of Object.entries(allMetrics)) {
  const filename = filePath.split('/').pop()!.replace('.json', '');
  const sepIdx   = filename.indexOf('_');
  const yearStr  = filename.slice(0, sepIdx);
  const dataSlug = filename.slice(sepIdx + 1);
  const year     = parseInt(yearStr);
  byYear[year]   ??= [];
  byYear[year].push({ dataSlug, metrics: (raw as any).default ?? raw });
}

const seasonSummaries = Object.entries(byYear)
  .sort(([a], [b]) => parseInt(a) - parseInt(b))
  .map(([yearStr, races]) => {
    const year     = parseInt(yearStr);
    const avgVol   = +(races.reduce((s, r) => s + (r.metrics.volatility_score ?? 0), 0) / races.length).toFixed(4);
    const totalInv = races.reduce((s, r) => s + (r.metrics.total_lap_inversions ?? 0), 0);
    return { year, raceCount: races.length, avgVol, totalInv, color: SEASON_COLORS[year] ?? '#7070a0' };
  });

const totalRaces      = seasonSummaries.reduce((s, y) => s + y.raceCount, 0);
const totalInversions = seasonSummaries.reduce((s, y) => s + y.totalInv, 0);
---

<Base title="Home" activeNav="home">

  <!-- ═══════════════════════════════════════════════════════════ HERO -->
  <section class="hero">
    <div class="hero-speed-lines"></div>
    <div class="hero-glow"></div>
    <div class="hero-angle-block"></div>

    <div class="hero-inner">
      <div class="hero-eyebrow">
        <span class="eyebrow-dot"></span>
        Algorithm &nbsp;&times;&nbsp; F1 &nbsp;&times;&nbsp; Data
      </div>

      <h1 class="hero-title">
        <span class="hero-t1">F1 RACE CHAOS</span>
        <span class="hero-t2">ANALYZER</span>
      </h1>

      <p class="hero-sub">
        Measuring overtaking turbulence using <strong>inversion counting</strong>
        across 2024, 2025, and 2026. Did the new regulations actually produce more exciting racing?
      </p>

      <div class="hero-ctas">
        <a href="/2026" class="cta-primary">2026 Season &nbsp;&rarr;</a>
        <a href="/compare" class="cta-secondary">Compare All Years</a>
      </div>
    </div>
  </section>

  <!-- ════════════════════════════════════════════════════ STATS BAND -->
  <div class="stats-band">
    <div class="stats-band-inner">
      <div class="sb-item">
        <span class="sb-num count-up" data-target={totalRaces}>{totalRaces}</span>
        <span class="sb-label">Races Analyzed</span>
      </div>
      <div class="sb-sep"></div>
      <div class="sb-item">
        <span class="sb-num count-up" data-target={totalInversions}>{totalInversions.toLocaleString()}</span>
        <span class="sb-label">Lap Inversions</span>
      </div>
      <div class="sb-sep"></div>
      <div class="sb-item">
        <span class="sb-num">3</span>
        <span class="sb-label">Seasons Covered</span>
      </div>
      <div class="sb-sep"></div>
      <div class="sb-item">
        <span class="sb-num">13</span>
        <span class="sb-label">Analytics Modules</span>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════ MAIN CONTENT -->
  <div class="container home-body">

    <!-- ── Season cards ──────────────────────────────────────── -->
    <div class="home-section">
      <div class="hs-label">Explore by Season</div>
      <div class="season-cards">
        {seasonSummaries.map((s, i) => {
          const cssVar = `--y${s.year}-color`;
          return (
            <a
              class="scard"
              href={`/${s.year}`}
              style={`--c: ${s.color}; animation-delay: ${0.05 + i * 0.12}s;`}
            >
              <div class="scard-bg-year">{s.year}</div>
              <div class="scard-top">
                <div class="scard-year" style={`color: var(${cssVar})`}>{s.year}</div>
                <div class="scard-badge">{s.raceCount} Races</div>
              </div>
              <div class="scard-div"></div>
              <div class="scard-stats">
                <div class="scard-stat">
                  <div class="scard-n" style={`color: var(${cssVar})`}>{s.avgVol}</div>
                  <div class="scard-l">Avg Volatility</div>
                </div>
                <div class="scard-stat">
                  <div class="scard-n" style={`color: var(${cssVar})`}>{s.totalInv.toLocaleString()}</div>
                  <div class="scard-l">Total Inversions</div>
                </div>
              </div>
              <div class="scard-arrow">Explore {s.year} season &nbsp;&rarr;</div>
            </a>
          );
        })}
      </div>
    </div>

    <!-- ── Algorithm explainer ───────────────────────────────── -->
    <div class="home-section">
      <div class="hs-label">How We Measure Chaos</div>
      <div class="algo-panel">
        <div class="algo-step">
          <div class="algo-n">01</div>
          <div class="algo-title">Inversion</div>
          <div class="algo-body">
            Driver A starts P6 but runs in P2 after lap 8 &mdash; they are now ahead of 4 drivers
            who started ahead of them. That's <strong>4 inversions</strong> on that lap.
            More inversions = more overtaking = more chaotic race.
          </div>
        </div>
        <div class="algo-arrow">&rarr;</div>
        <div class="algo-step">
          <div class="algo-n">02</div>
          <div class="algo-title">Fenwick Tree</div>
          <div class="algo-body">
            Per-lap inversions counted in <strong>O(n log n)</strong> using a Binary Indexed Tree.
            Start&rarr;finish delta uses Merge Sort. Both give exact counts fast enough to run
            across every lap of every race.
          </div>
        </div>
        <div class="algo-arrow">&rarr;</div>
        <div class="algo-step">
          <div class="algo-n">03</div>
          <div class="algo-title">Volatility Score</div>
          <div class="algo-body">
            <code class="algo-code">inversions &divide; (grid &times; laps)</code>
            <br /><br />
            Normalised so a 20-car 70-lap race and a 20-car 50-lap race are
            comparable on the same scale. Higher = more chaotic.
          </div>
        </div>
      </div>
    </div>

    <!-- ── Season trend chart ────────────────────────────────── -->
    <div class="home-section">
      <div class="hs-label">Average Volatility Trend</div>
      <div class="hs-desc">
        Each point is a full season's average volatility score. Watch how the numbers shift as technical regulations change.
      </div>
      <div class="card" style="padding: 24px 32px 8px;">
        <SeasonTrendChart seasons={seasonSummaries} client:visible />
      </div>
    </div>

    <!-- ── Compare CTA ───────────────────────────────────────── -->
    <div class="compare-cta">
      <div class="cta-inner-left">
        <div class="cta-overline">Cross-Season Analysis</div>
        <div class="cta-title">Is 2025 more chaotic than 2024?</div>
        <div class="cta-sub">
          Circuit-by-circuit comparisons, average volatility per season,
          and head-to-head inversion breakdowns &mdash; side by side.
        </div>
      </div>
      <a href="/compare" class="cta-arrow-btn">Full Comparison &nbsp;&rarr;</a>
    </div>

  </div>
</Base>

<style>
/* ═══════════════════════════════════════════════════════════════ HERO */
